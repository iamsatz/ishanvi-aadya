# Supabase (required for cloud sync)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Invisible shared family account (no-login mode).
# The app auto-signs into this one account so kids never see a login,
# and phone uploads still appear on the TV (same account everywhere).
# This MUST be the account that already holds Ishanvi/Aadya's data,
# and that account MUST have a password set (Supabase > Auth > Users).
VITE_SHARED_ACCOUNT_EMAIL=family@example.com
VITE_SHARED_ACCOUNT_PASSWORD=set_a_strong_password

# After adding keys:
# 1. Run supabase/schema.sql in SQL editor
# 2. Run supabase/migrations/open-signup.sql to open signup
# 3. Set a password on the shared family account (Auth > Users)
# 4. Deploy supabase/functions/tutor with GEMINI_API_KEY secret
# See docs/SUPABASE-SETUP.md
